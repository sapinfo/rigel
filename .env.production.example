# ─── Rigel 프로덕션 환경변수 ─────────────────────────────
# 사용법: cp .env.production.example .env
# 그리고 아래 값을 Supabase 셀프호스팅 .env (supabase/docker/.env)에서 복사.

# Supabase 접속 URL (kong gateway)
# 기본값: http://localhost:8000 (Supabase가 같은 호스트면)
# 외부 접속 시 서버 IP/도메인으로 변경 (예: https://supabase.example.com)
PUBLIC_SUPABASE_URL=http://localhost:8000

# Supabase ANON_KEY — supabase/docker/.env 의 ANON_KEY 값 그대로 복사
# (generate-keys.sh 실행 후 자동 생성된 값)
PUBLIC_SUPABASE_ANON_KEY=

# Rigel 앱 사이트 URL (브라우저 접속 주소)
SITE_URL=http://localhost:3000

# Rigel 앱 포트
APP_PORT=3000
