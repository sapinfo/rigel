# ─── Rigel 프로덕션 환경변수 ───
# 이 파일을 .env로 복사한 후 값을 수정하세요.
# cp .env.production.example .env

# ─── 필수: 보안 키 (반드시 변경!) ───
POSTGRES_PASSWORD=여기에_강력한_비밀번호_입력
JWT_SECRET=여기에_32자_이상의_시크릿_키_입력

# ─── Supabase Keys ───
# JWT_SECRET으로 생성된 키. 아래 기본값은 개발용입니다.
# 프로덕션에서는 https://supabase.com/docs/guides/self-hosting 참고하여 생성
SUPABASE_ANON_KEY=여기에_anon_key_입력
SUPABASE_SERVICE_KEY=여기에_service_key_입력

# ─── 사이트 URL ───
# 실제 접속 URL (HTTPS 권장)
SITE_URL=http://서버IP:3000

# ─── 포트 설정 (기본값 사용 시 변경 불필요) ───
APP_PORT=3000
API_PORT=8000
POSTGRES_PORT=5432
