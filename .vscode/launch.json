{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "SvelteKit: Dev Server",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--inspect",
        "${workspaceFolder}/node_modules/vite/bin/vite.js",
        "dev"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ],
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "SvelteKit: Chrome",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "/@fs/*": "*",
        "/src/*": "${webRoot}/*"
      },
      "userDataDir": "${workspaceFolder}/.vscode/.chrome-debug-profile"
    },
    {
      "type": "msedge",
      "request": "launch",
      "name": "SvelteKit: Edge",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "/@fs/*": "*",
        "/src/*": "${webRoot}/*"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "SvelteKit: Build + Preview",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "preview"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "production"
      }
    }
  ],
  "compounds": [
    {
      "name": "F5: Full Stack (Server + Chrome)",
      "configurations": ["SvelteKit: Dev Server", "SvelteKit: Chrome"],
      "stopAll": true,
      "presentation": {
        "group": "fullstack",
        "order": 1
      }
    },
    {
      "name": "F5: Full Stack (Server + Edge)",
      "configurations": ["SvelteKit: Dev Server", "SvelteKit: Edge"],
      "stopAll": true,
      "presentation": {
        "group": "fullstack",
        "order": 2
      }
    }
  ]
}
