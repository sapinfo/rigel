    "svelte-check": "^4.1.0",
    "tailwindcss": "^3.4.17",
    "tslib": "^2.8.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
